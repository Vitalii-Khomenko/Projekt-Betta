# Betta-Morpho environment example
# Copy to .env and adjust for your lab or autonomous workflow.

BETTA_PROFILE=x10
BETTA_TARGET=127.0.0.1
BETTA_PORTS=top20
BETTA_TRANSPORT=connect
BETTA_ARTIFACT=artifacts/scanner_model.json
BETTA_REPORT=artifacts/snn_model.json
BETTA_CHECKPOINT_EVERY=1000
BETTA_PROGRESS_LOG=1
BETTA_VERIFY_WITH_NMAP=0
BETTA_SPEED_LEVEL=
BETTA_INTERFACE=eth0
BETTA_SCAN_SECONDS=30
BETTA_PYTHON=.venv/bin/python
BETTA_LIVE_CAPTURE_SECONDS=30
